# Portfolio Environment Variables
# Copy this file to .env.local and update with your values

# API Configuration
VITE_API_BASE_URL=http://localhost:3000

# Contact Form Settings
VITE_CONTACT_EMAIL=your-email@example.com
VITE_CONTACT_API_ENDPOINT=https://api.example.com/contact

# Social Links
VITE_GITHUB_URL=https://github.com/yourprofile
VITE_LINKEDIN_URL=https://linkedin.com/in/yourprofile
VITE_INSTAGRAM_URL=https://instagram.com/yourprofile
VITE_TWITTER_URL=https://twitter.com/yourprofile

# Google Analytics (optional)
VITE_GA_ID=

# Theme Settings
VITE_THEME=dark
